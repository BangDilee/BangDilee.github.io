  <div class="quote-box">
    <div class="quote-text" id="quoteText">"Jadi anak baik itu bukan pilihan, tapi gaya hidup"</div>
    <div class="quote-author">— BangDilee</div>
    <button class="new-quote-btn" id="newQuoteBtn">Kutipan Baru ✨</button>
  </div>
</section>

<!-- COUNTDOWN -->
<div class="countdown-section">
  <h2>⏰ <span style="color: var(--red);">Menuju Wisuda</span></h2>
  <p>semangat terus, Bang!</p>
  <div class="countdown-timer">
    <div class="countdown-item"><div class="countdown-number" id="days">0</div><div class="countdown-label">Hari</div></div>
    <div class="countdown-item"><div class="countdown-number" id="hours">0</div><div class="countdown-label">Jam</div></div>
    <div class="countdown-item"><div class="countdown-number" id="minutes">0</div><div class="countdown-label">Menit</div></div>
    <div class="countdown-item"><div class="countdown-number" id="seconds">0</div><div class="countdown-label">Detik</div></div>
  </div>
</div>

<!-- CONTACT -->
<section id="contact">
  <div class="contact-container">
    <h2>Hubungi <span>BangDilee</span></h2>
    <p>Santai aja chat-nya. Asal bukan lagi pas push rank atau lagi asik ngoding 😄</p>
    <div class="contact-info">
      <!-- 🔒 Email obfuscation: dilindungi dari bot scraper -->
      <a href="mailto:dileemania@gmail.com" id="emailLink"><i class="fas fa-envelope"></i> <span id="emailDisplay">dileemania@gmail.com</span></a>
      <a href="tel:085219361530"><i class="fas fa-phone"></i> 0852 1936 1530</a>
    </div>
    <div class="socials" style="justify-content: center;">
      <a href="https://instagram.com/bangdilee" target="_blank" rel="noopener noreferrer"><i class="fab fa-instagram"></i></a>
      <a href="https://twitter.com/bangdilee" target="_blank" rel="noopener noreferrer"><i class="fab fa-twitter"></i></a>
      <a href="https://github.com/bangdilee" target="_blank" rel="noopener noreferrer"><i class="fab fa-github"></i></a>
      <a href="https://tiktok.com/@bangdilee" target="_blank" rel="noopener noreferrer"><i class="fab fa-tiktok"></i></a>
    </div>
  </div>
  <div class="footer-note">
    <span>© 2025 BangDilee — dari Soppeng untuk dunia, tetap jadi anak baik ✨</span>
    <a href="#home" class="scroll-top">↑</a>
  </div>
</section>

<script>
  // 🔒 Keamanan: Prevent Right Click (opsional, proteksi dasar)
  document.addEventListener('contextmenu', (e) => {
    // Izinkan right click di area input (untuk kemudahan user)
    if (e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
      // e.preventDefault(); // Uncomment jika ingin blokir right click
    }
  });

  // 🔒 Keamanan: Detect DevTools (peringatan sederhana)
  (function() {
    const startTime = performance.now();
    function checkDevTools() {
      const now = performance.now();
      if (now - startTime > 100) {
        console.log("%c🔒 Halo! Kalau mau liat-liat kode, silahkan ya. Tapi tolong hargai karya orang 😊", "color: #e63333; font-size: 14px");
      }
    }
    checkDevTools();
  })();

  // 🔒 Keamanan: Rate Limiting untuk tombol quote
  let lastQuoteClick = 0;
  const quoteBtn = document.getElementById('newQuoteBtn');
  const rateLimitToast = document.getElementById('rateLimitToast');
  
  function showRateLimitToast() {
    rateLimitToast.classList.add('show');
    setTimeout(() => {
      rateLimitToast.classList.remove('show');
    }, 2000);
  }

  // Preloader
  window.addEventListener('load', () => {
    document.getElementById('preloader').classList.add('hide');
    setTimeout(() => {
      document.getElementById('preloader').style.display = 'none';
    }, 500);
  });

  // Progress Bar
  window.addEventListener('scroll', () => {
    const winScroll = document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    document.getElementById('progressBar').style.width = scrolled + '%';
  });

  // Custom Cursor
  const cursor = document.getElementById('cursor');
  const cursorFollower = document.getElementById('cursorFollower');
  if (cursor && cursorFollower) {
    document.addEventListener('mousemove', (e) => {
      cursor.style.left = e.clientX + 'px';
      cursor.style.top = e.clientY + 'px';
      cursorFollower.style.left = e.clientX + 'px';
      cursorFollower.style.top = e.clientY + 'px';
    });
  }

  // Scroll Reveal
  const sections = document.querySelectorAll('section');
  const revealSection = () => {
    sections.forEach(section => {
      const sectionTop = section.getBoundingClientRect().top;
      const windowHeight = window.innerHeight;
      if (sectionTop < windowHeight - 100) {
        section.classList.add('revealed');
      }
    });
  };
  window.addEventListener('scroll', revealSection);
  revealSection();

  // Dark/Light Mode
  const themeToggle = document.getElementById('themeToggle');
  const themeIcon = document.getElementById('themeIcon');
  themeToggle.addEventListener('click', () => {
    document.body.classList.toggle('light-mode');
    if (document.body.classList.contains('light-mode')) {
      themeIcon.classList.remove('fa-moon');
      themeIcon.classList.add('fa-sun');
    } else {
      themeIcon.classList.remove('fa-sun');
      themeIcon.classList.add('fa-moon');
    }
  });

  // Music Player
  const musicPlayer = document.getElementById('musicPlayer');
  const bgMusic = document.getElementById('bgMusic');
  const musicIcon = document.getElementById('musicIcon');
  let isPlaying = false;
  musicPlayer.addEventListener('click', () => {
    if (isPlaying) {
      bgMusic.pause();
      musicIcon.classList.remove('fa-pause');
      musicIcon.classList.add('fa-music');
    } else {
      bgMusic.play().catch(e => console.log('Audio play error:', e));
      musicIcon.classList.remove('fa-music');
      musicIcon.classList.add('fa-pause');
    }
    isPlaying = !isPlaying;
  });

  // Quote Generator (tema anak baik) + 🔒 Rate Limiting
  const quotes = [
    { text: "Jadi anak baik itu bukan pilihan, tapi gaya hidup", author: "BangDilee" },
    { text: "Belajar ngoding pelan-pelan, yang penting istiqomah", author: "BangDilee" },
    { text: "Dari akuakultur ke kode — perjalanan yang seru", author: "BangDilee" },
    { text: "Main game gapapa, asal jangan lupa ibadah", author: "BangDilee" },
    { text: "Mimpi besar, jalan pelan, tetap jadi anak baik", author: "BangDilee" },
    { text: "Software engineer dari Soppeng, itu targetnya", author: "BangDilee" }
  ];
  const quoteText = document.getElementById('quoteText');
  const quoteAuthor = document.querySelector('.quote-author');
  
  if (quoteBtn) {
    quoteBtn.addEventListener('click', () => {
      const now = Date.now();
      if (now - lastQuoteClick < 2000) {
        showRateLimitToast();
        return;
      }
      lastQuoteClick = now;
      const random = Math.floor(Math.random() * quotes.length);
      quoteText.textContent = `"${quotes[random].text}"`;
      quoteAuthor.textContent = `— ${quotes[random].author}`;
    });
  }

  // Countdown (target wisuda)
  function updateCountdown() {
    const targetDate = new Date('June 30, 2026 00:00:00').getTime();
    const now = new Date().getTime();
    const distance = targetDate - now;
    if (distance > 0) {
      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (24 * 60 * 60 * 1000)) / (60 * 60 * 1000));
      const minutes = Math.floor((distance % (60 * 60 * 1000)) / (60 * 1000));
      const seconds = Math.floor((distance % (60 * 1000)) / 1000);
      document.getElementById('days').textContent = days;
      document.getElementById('hours').textContent = hours;
      document.getElementById('minutes').textContent = minutes;
      document.getElementById('seconds').textContent = seconds;
    }
  }
  setInterval(updateCountdown, 1000);
  updateCountdown();
  // Gallery Data — 🔒 Dengan sanitasi dasar
  const galleryData = {
    gaming: [
      { img: "image/gaming/game1.jpg", caption: "Momen push rank" },
      { img: "image/gaming/game2.jpg", caption: "Squad ML" }
    ],
    kampus: [
      { img: "image/kampus/unhas1.jpg", caption: "Suasana kampus" },
      { img: "image/kampus/unhas2.jpg", caption: "Praktikum akuakultur" }
    ],
    random: [
      { img: "image/random/mancing1.jpg", caption: "Mancing santai" },
      { img: "image/random/mancing2.jpg", caption: "Keseharian" }
    ]
  };

  // 🔒 Sanitasi caption (mencegah XSS)
  function sanitizeText(text) {
    if (!text) return '';
    return text.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  function renderGallery(category) {
    const grid = document.getElementById("galleryGrid");
    const items = galleryData[category];
    if (!items || items.length === 0) {
      grid.innerHTML = `<div class="empty-gallery">📂 Belum ada foto di folder ${sanitizeText(category)}. Taruh foto JPG/PNG di folder image/${sanitizeText(category)}/</div>`;
      return;
    }
    grid.innerHTML = items.map(item => `
      <div class="gallery-card">
        <img src="${item.img}" alt="${sanitizeText(item.caption)}" loading="lazy" onerror="this.src='https://placehold.co/400x200?text=Gambar+belum+ada'">
        <div class="caption">${sanitizeText(item.caption)}</div>
      </div>
    `).join('');
  }

  document.querySelectorAll(".tab-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      renderGallery(btn.getAttribute("data-category"));
    });
  });
  renderGallery("gaming");

  // Navbar Scroll Spy
  const navLinksDoc = document.querySelectorAll('.nav-links a');
  const allSections = document.querySelectorAll('section, .countdown-section');
  window.addEventListener('scroll', () => {
    let current = '';
    allSections.forEach(section => {
      const sectionTop = section.offsetTop - 100;
      if (scrollY >= sectionTop && section.id) {
        current = section.id;
      }
    });
    navLinksDoc.forEach(link => {
      link.classList.remove('active');
      if (link.getAttribute('href') === `#${current}`) {
        link.classList.add('active');
      }
    });
  });

  // Hamburger Menu
  const menuToggle = document.getElementById('menuToggle');
  const navLinksContainer = document.getElementById('navLinks');
  if (menuToggle) {
    menuToggle.addEventListener('click', () => navLinksContainer.classList.toggle('active'));
    navLinksDoc.forEach(link => link.addEventListener('click', () => navLinksContainer.classList.remove('active')));
  }

  // 🔒 HTTPS Enforcement (redirect ke HTTPS jika perlu)
  if (location.protocol !== 'https:' && location.hostname !== 'localhost' && !location.hostname.includes('127.0.0.1')) {
    // Comment: Untuk GitHub Pages sudah otomatis HTTPS, tidak perlu redirect manual
    console.log('🔒 Running on HTTPS mode');
  }

  // 🔒 Prevent form submission if any (tambahan proteksi)
  const allForms = document.querySelectorAll('form');
  allForms.forEach(form => {
    form.addEventListener('submit', (e) => {
      console.log('Form submission prevented for security');
      e.preventDefault();
    });
  });
</script>
</body>
</html>